<div class="panel table-wrap">
  <div class="table-head">
    <h2>Amortization Preview</h2>
    <span class="hint" id="tableHint">Payments 1-12</span>
  </div>
  <div class="table-scroll">
    <table>
      <thead>
        <tr>
          <th>Payment</th>
          <th>Principal</th>
          <th>Interest</th>
          <th>Extra</th>
          <th>Balance</th>
        </tr>
      </thead>
      <tbody id="schedule"></tbody>
    </table>
  </div>
  <div class="table-pagination" aria-label="Amortization pagination">
    <button type="button" class="secondary pagination-button" data-page-action="first" aria-label="First page">First</button>
    <button type="button" class="secondary pagination-button" data-page-action="prev" aria-label="Previous page">Prev</button>
    <span class="pagination-status" id="tablePageStatus" aria-live="polite">Page 1 of 1</span>
    <button type="button" class="secondary pagination-button" data-page-action="next" aria-label="Next page">Next</button>
    <button type="button" class="secondary pagination-button" data-page-action="last" aria-label="Last page">Last</button>
  </div>
</div>
