<div class="panel">
  <div class="summary" aria-label="Loan summary">
    <div class="metric costs">
      <span>Avg accelerated monthly</span>
      <strong id="allInOut">$0</strong>
    </div>
    <div class="metric interest">
      <span>Accelerated interest</span>
      <strong id="interestOut">$0</strong>
    </div>
    <div class="metric payoff">
      <span>Accelerated payoff</span>
      <strong id="payoffOut">0 mo</strong>
    </div>
    <div class="metric savings">
      <span>Interest saved</span>
      <strong id="interestSavedOut">$0</strong>
    </div>
    <div class="metric payment">
      <span>Base monthly payment</span>
      <strong id="monthlyOut">$0</strong>
    </div>
    <div class="metric baseline">
      <span>Base interest</span>
      <strong id="baseInterestOut">$0</strong>
    </div>
    <div class="metric baseline">
      <span>Base payoff</span>
      <strong id="basePayoffOut">0 mo</strong>
    </div>
    <div class="metric savings">
      <span>Time saved</span>
      <strong id="timeSavedOut">0 mo</strong>
    </div>
  </div>
  <div class="chart-wrap">
    <canvas id="chart" width="1000" height="320" aria-label="Balance over time"></canvas>
  </div>
</div>
